{
  "name": "pokeapi-cli",
  "version": "0.1.0",
  "description": "CLI for the PokeAPI (pokemon and pokemon-species endpoints).",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "pkmn": "./bin/pkmn.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -w -p .",
    "lint": "biome check ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit -p ."
  },
  "keywords": [
    "pokeapi-cli",
    "pokeapi",
    "pokemon",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpbullalayao/pokemon-ai.git",
    "directory": "general/pokeapi-cli"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.2"
  }
}
